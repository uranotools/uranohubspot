{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["*"],
      "@models/*": ["*"],
      "@modules/*": ["*"]
    }
  },
  "include": [
    "config.ts",
    "Plugins/**/*.ts",
    "urano.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
